{
    "name": "khalid/kasir-smart-api",
    "description": "AI-Powered Smart API for Kasir Percetakan - enables intelligent product search, AI chatbot integration, and smart price calculation for any Laravel-based Kasir Percetakan project.",
    "version": "1.2.0",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Khalid R",
            "email": "admin@kasirpercetakan.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0",
        "illuminate/routing": "^10.0|^11.0",
        "illuminate/database": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Khalid\\KasirSmartApi\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Khalid\\KasirSmartApi\\KasirSmartApiServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
